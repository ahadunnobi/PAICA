# ============================================================
# Personal AI Communication Agent — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── App ────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://paica:paica_pass@localhost:5432/paica_db
POSTGRES_USER=paica
POSTGRES_PASSWORD=paica_pass
POSTGRES_DB=paica_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Vector DB (Pinecone) ───────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENV=us-east-1-aws
PINECONE_INDEX=paica-memory

# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook/telegram

# ─── WhatsApp (Meta Business API) ───────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_WEBHOOK_URL=https://yourdomain.com/webhook/whatsapp

# ─── Instagram (Graph API) ──────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_VERIFY_TOKEN=your-custom-verify-token

# ─── Email (IMAP + SMTP) ────────────────────────────────────
EMAIL_ADDRESS=you@gmail.com
EMAIL_PASSWORD=your-app-password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ─── Toxicity / Safety ──────────────────────────────────────
PERSPECTIVE_API_KEY=your-perspective-api-key

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
